<Window x:Class="BluetoothLockScreen.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="蓝牙锁屏监控 v1.0" Height="350" Width="500"
        MinHeight="300" MinWidth="400"
        WindowStartupLocation="CenterScreen"
        Icon="Resources/app.ico"
        Closing="MainWindow_Closing">   <!-- 新增 Closing 事件 -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- 状态显示区 -->
        <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2"
                Margin="10" Background="#F0F0F0" CornerRadius="8">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="StatusText" Text="未开始监控"
                           FontSize="18" FontWeight="Bold" TextAlignment="Center"/>
                <TextBlock x:Name="RssiText" Text="RSSI: --"
                           FontSize="14" Margin="0,10,0,0" TextAlignment="Center"/>
                <TextBlock x:Name="DeviceNameText" Text="未选择设备"
                           FontSize="12" Foreground="Gray" TextAlignment="Center"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- 开始监控按钮 -->
        <Button x:Name="StartStopButton" Grid.Row="0" Grid.Column="1"
                Width="120" Height="120" Margin="10"
                FontSize="16" FontWeight="Bold" Click="StartStopButton_Click">
            <TextBlock TextAlignment="Center">
                <Run Text="&#x25B6;"/><LineBreak/><Run Text="开始监控"/>
            </TextBlock>
        </Button>

        <!-- 设置按钮 -->
        <Button Grid.Row="1" Grid.Column="1" Width="120" Height="30"
                Margin="10,0,10,10" Content="⚙ 设置"
                FontSize="14" Click="SettingsButton_Click"/>
    </Grid>
</Window>
