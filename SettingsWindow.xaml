<Window x:Class="BluetoothLockScreen.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Height="600" Width="480"
        WindowStartupLocation="CenterOwner"
        Icon="Resources/app.ico"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- RSSI阈值设置 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="RSSI锁屏阈值 (dBm):" VerticalAlignment="Center" Width="140"/>
            <TextBox x:Name="RssiThresholdBox" Width="80" VerticalAlignment="Center"/>
            <TextBlock Text="（负值，如 -70）" VerticalAlignment="Center" Margin="5,0,0,0"/>
        </StackPanel>

        <!-- 手动输入蓝牙地址 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="设备蓝牙地址:" VerticalAlignment="Center" Width="100"/>
            <TextBox x:Name="ManualAddressBox" Width="180" VerticalAlignment="Center"
                     ToolTip="例如：A1:B2:C3:D4:E5:F6"/>
            <Button Content="保存地址" Width="80" Margin="5,0,0,0"
                    Click="SaveManualAddress_Click"/>
            <Button Content="测试连接" Width="80" Margin="5,0,0,0"
                    Click="TestConnection_Click"/>
        </StackPanel>
        <TextBlock Grid.Row="2" Text="* 可从 Windows 蓝牙设置 → 设备属性中查看地址"
                   FontSize="11" Foreground="Gray" Margin="0,0,0,5"/>
        <TextBlock x:Name="TestResultText" Grid.Row="3" Text=""
                   FontSize="12" Margin="0,0,0,5" Foreground="DarkGreen"/>

        <!-- 已配对设备区域 -->
        <StackPanel Grid.Row="4" Margin="0,10,0,5">
            <TextBlock Text="已配对的蓝牙设备（点击选择）" FontWeight="Bold" Margin="0,0,0,5"/>
            <Button x:Name="RefreshPairedButton" Content="刷新列表" Width="100"
                    Click="RefreshPairedButton_Click" Margin="0,0,0,5"/>
            <ListBox x:Name="PairedDeviceListBox" DisplayMemberPath="DisplayName"
                     SelectionChanged="PairedDeviceListBox_SelectionChanged"
                     Height="150"/>
        </StackPanel>

        <!-- 记录RSSI按钮及显示 -->
        <Button Grid.Row="5" Content="📝 记录当前RSSI值" Height="35"
                Margin="0,0,0,5" Click="RecordRssiButton_Click"/>
        <TextBlock Grid.Row="6" x:Name="LastRssiText" Text="尚未记录"
                   FontSize="12" Foreground="DimGray" Margin="0,0,0,5" TextWrapping="Wrap"/>

        <!-- 保存与关闭 -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="保存设置" Width="100" Height="30" Click="SaveButton_Click"/>
            <Button Content="取消" Width="100" Height="30" Margin="10,0,0,0"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
